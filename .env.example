# Database (MySQL 8 — docker compose up -d)
DATABASE_URL="mysql://km:kmpass@localhost:3306/km_system"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# App
PORT=3001
FRONTEND_URL=http://localhost:3000

# Auth
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES_DAYS=7

# Seed
SEED_ADMIN_PASSWORD=Admin@1234

# Cloudinary (สำหรับ UploadModule ภายหลัง)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# AI (ห้าม expose ไป frontend)
AI_PROVIDER=gemini
GEMINI_API_KEY=
